generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id                  Int                 @id @default(autoincrement())
  fullName            String
  email               String              @unique
  mobile              String
  passwordHash        String
  role                String              @default("student")
  emailVerified       Boolean             @default(false)
  verificationToken   String?             @db.Text
  passwordResetToken  String?             @db.Text
  passwordResetExpires DateTime?
  profileCompleted    Boolean             @default(false)
  dob                 String?
  gender              String?
  bloodGroup          String?
  nationality         String?
  religion            String?
  category            String?
  address             String?
  guardianName        String?
  guardianOccupation  String?
  guardianIncome      String?
  emergencyContact    String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  academicDetails     AcademicDetail?
  admissionForm       AdmissionForm?
  uploadedDocuments   UploadedDocument[]
  admissionStatus     AdmissionStatus?
  notifications       Notification[]
}

model AcademicDetail {
  id                  Int      @id @default(autoincrement())
  studentId           Int      @unique
  secondarySchool     String?
  secondaryBoard      String?
  secondaryPercentage Float?
  secondaryYear       Int?
  intermediateCollege String?
  intermediateBoard   String?
  intermediatePercentage Float?
  intermediateYear    Int?
  examName            String?
  examRank            String?
  examScore           String?
  examYear            Int?
  updatedAt           DateTime @updatedAt

  student             Student  @relation(fields: [studentId], references: [id])
}

model AdmissionForm {
  id                  Int      @id @default(autoincrement())
  studentId           Int      @unique
  course              String
  branch              String
  admissionCategory   String
  hostelRequired      Boolean  @default(false)
  scholarshipRequired Boolean  @default(false)
  previousInstitution String?
  declarationAccepted Boolean
  draft               Boolean  @default(true)
  submittedAt         DateTime?
  status              String   @default("draft")
  updatedAt           DateTime @updatedAt

  student             Student  @relation(fields: [studentId], references: [id])
}

model UploadedDocument {
  id                 Int      @id @default(autoincrement())
  studentId          Int
  documentType       String
  fileName           String
  filePath           String
  verified           Boolean  @default(false)
  verificationNotes  String?
  createdAt          DateTime @default(now())

  student            Student  @relation(fields: [studentId], references: [id])
}

model AdmissionStatus {
  id                Int      @id @default(autoincrement())
  studentId         Int      @unique
  applicationStatus String   @default("draft")
  documentStatus    String   @default("pending")
  auditNotes        String?
  updatedAt         DateTime @updatedAt

  student           Student  @relation(fields: [studentId], references: [id])
}

model Admin {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Notification {
  id         Int      @id @default(autoincrement())
  studentId  Int
  title      String
  message    String
  read       Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())

  student    Student  @relation(fields: [studentId], references: [id])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int?
  action     String
  target     String
  details    String?
  createdAt  DateTime @default(now())
}
